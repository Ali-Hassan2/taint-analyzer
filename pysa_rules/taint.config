{
  "sources": [
    {
      "name": "UserControlled",
      "comment": "Data that may be influenced by the user, LLM, or MCP tool arguments."
    },
    {
      "name": "MCPArgument",
      "comment": "Alias semantic for MCP tool parameters (same propagation as UserControlled in rules)."
    }
  ],
  "sinks": [
    {
      "name": "ShellExecution",
      "comment": "Process or shell execution (command injection)."
    },
    {
      "name": "ArbitraryExecution",
      "comment": "eval/exec/compile and similar dynamic code."
    },
    {
      "name": "FileSystemAccess",
      "comment": "File open, delete, or tree operations that may leak or corrupt data."
    },
    {
      "name": "NetworkEgress",
      "comment": "HTTP/URL fetches — SSRF or data exfiltration."
    },
    {
      "name": "Deserialization",
      "comment": "pickle/marshal and other unsafe deserialization."
    },
    {
      "name": "LLMPrompt",
      "comment": "Structured LLM API calls where prompt content may include untrusted text."
    }
  ],
  "features": [],
  "rules": [
    {
      "name": "MCP user input to shell",
      "code": 6101,
      "sources": ["UserControlled", "MCPArgument"],
      "sinks": ["ShellExecution"],
      "message_format": "[MCP/Pysa] User-influenced data may reach a shell/process execution sink."
    },
    {
      "name": "MCP user input to arbitrary execution",
      "code": 6102,
      "sources": ["UserControlled", "MCPArgument"],
      "sinks": ["ArbitraryExecution"],
      "message_format": "[MCP/Pysa] User-influenced data may reach eval/exec/compile."
    },
    {
      "name": "MCP user input to filesystem",
      "code": 6103,
      "sources": ["UserControlled", "MCPArgument"],
      "sinks": ["FileSystemAccess"],
      "message_format": "[MCP/Pysa] User-influenced data may reach a filesystem sink."
    },
    {
      "name": "MCP user input to network",
      "code": 6104,
      "sources": ["UserControlled", "MCPArgument"],
      "sinks": ["NetworkEgress"],
      "message_format": "[MCP/Pysa] User-influenced data may reach a network/URL sink (SSRF risk)."
    },
    {
      "name": "MCP user input to deserialization",
      "code": 6105,
      "sources": ["UserControlled", "MCPArgument"],
      "sinks": ["Deserialization"],
      "message_format": "[MCP/Pysa] User-influenced data may reach unsafe deserialization."
    },
    {
      "name": "MCP user input to LLM prompt",
      "code": 6106,
      "sources": ["UserControlled", "MCPArgument"],
      "sinks": ["LLMPrompt"],
      "message_format": "[MCP/Pysa] User-influenced data may reach an LLM API prompt (prompt injection)."
    }
  ],
  "implicit_sources": [],
  "implicit_sinks": []
}
